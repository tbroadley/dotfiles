# agent-tokens.env — credentials injected into every pi agent's environment
# by extensions/agent-tokens.ts.
#
# Copy to ~/.pi/agent/agent-tokens.env on the host, fill in real values, and
# `chmod 600` it. This example lists KEY names only — the real file holds
# secrets and is gitignored (never commit it).
#
# Only include tokens that are (a) a single static value and (b) read from an
# env var by a skill. Skills that use interactive logins / OAuth / short-lived
# CLI tokens (bitwarden, gws-*, hawk/aws/gh) are NOT managed here.

# Todoist (todoist skill) — Authorization: Bearer $TODOIST_TOKEN
TODOIST_TOKEN=

# Airtable (airtable skill) — personal access token, Authorization: Bearer
AIRTABLE_TOKEN=

# Linear (linear skill) — Authorization: $LINEAR_API_KEY  (no "Bearer" prefix)
LINEAR_API_KEY=

# Datadog (datadog skill) — API + application keys and site
DD_API_KEY=
DD_APP_KEY=
DD_SITE=
